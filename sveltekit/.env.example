# Raksara SvelteKit Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env — it may contain private identifiers.

# Site metadata
PUBLIC_SITE_URL=https://example.com
PUBLIC_SITE_NAME=Your Site Name

# Content repository (used in CI)
# PUBLIC_CONTENT_REPO=owner/repo-name

# Giscus comments (get these from giscus.app)
# PUBLIC_GISCUS_REPO=owner/repo
# PUBLIC_GISCUS_REPO_ID=
# PUBLIC_GISCUS_CATEGORY=General
# PUBLIC_GISCUS_CATEGORY_ID=

# Google AdSense (optional)
# PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-0000000000000000

# Cloudflare Turnstile (admin login protection)
# Get your site key from dash.cloudflare.com → Turnstile
# Localhost automatically uses Cloudflare's pass-test site key.
# PUBLIC_TURNSTILE_SITE_KEY=0x4AAA...
