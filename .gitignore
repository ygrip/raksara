sveltekit/build/
sveltekit/.svelte-kit/
sveltekit/static/content/
sveltekit/static/metadata/

# Generated static assets
sveltekit/static/vendor/
sveltekit/static/vendor-chart.min.js
sveltekit/static/vendor-highlight.min.js
