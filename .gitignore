!sveltekit/svelte.config.js
!sveltekit/package.json
!sveltekit/package-lock.json
!sveltekit/tsconfig.json
!sveltekit/vite.config.ts
!sveltekit/.npmrc
!sveltekit/.env.example
!sveltekit/tailwind.config.js
!sveltekit/postcss.config.js

# Project plan (internal)
plan/

# Environment — never commit actual values
sveltekit/.env
sveltekit/.env.*
